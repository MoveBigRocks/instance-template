{
	email support@movebigrocks.com
}

# Standalone public Move Big Rocks site and runtime host routing.
# Copy to /etc/caddy/Caddyfile when Caddy is managed on the same host.

movebigrocks.com, www.movebigrocks.com {
	encode zstd gzip

	log {
		output file /var/log/caddy/movebigrocks-site.log
	}

	reverse_proxy 127.0.0.1:8080 127.0.0.1:8081 {
		lb_policy first
		health_uri /health
		health_interval 2s
		health_timeout 5s
		fail_duration 10s
	}
}

admin.movebigrocks.com {
	encode zstd gzip

	log {
		output file /var/log/caddy/movebigrocks-admin.log
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Allow Grafana iframe embedding — the app proxy handles auth via HMAC cookie.
	# Do NOT add X-Frame-Options globally on admin subdomains.
	# Do NOT add `handle /metrics { respond 404 }` — the app serves its own
	# metrics page (embedded Grafana dashboards) behind session auth.
	# Do NOT add `handle /grafana/*` with a direct proxy to Grafana — the app
	# has its own authenticated reverse proxy that validates access cookies.
	header /grafana/* {
		-X-Frame-Options
	}

	reverse_proxy 127.0.0.1:8080 127.0.0.1:8081 {
		lb_policy first
		health_uri /health
		health_interval 2s
		health_timeout 5s
		fail_duration 10s
	}
}

api.movebigrocks.com {
	encode zstd gzip

	log {
		output file /var/log/caddy/movebigrocks-api.log
	}

	reverse_proxy 127.0.0.1:8080 127.0.0.1:8081 {
		lb_policy first
		health_uri /health
		health_interval 2s
		health_timeout 5s
		fail_duration 10s
	}
}
