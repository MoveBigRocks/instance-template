# Move Big Rocks Production Environment
# In a normal instance repo deploy, this file is generated from:
# - mbr.instance.yaml (non-secret desired state)
# - GitHub secrets (sensitive credentials and tokens)
# This example exists as a fallback and for debugging.

# Server (bind to localhost - Caddy handles external traffic)
# NOTE: Do NOT set PORT in this file for blue/green deployments.
# Port is set by systemd slot units (mbr-blue:8080, mbr-green:8081).
ENVIRONMENT=production
DOMAIN=app.example.com

# Database (PostgreSQL)
DATABASE_DSN=postgres://mbr:change-me@postgres.example.com:5432/mbr?sslmode=require

# Authentication
# Generate with: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRY=24h
MAGIC_LINK_TTL=15m
# Cookie domain for cross-subdomain auth (e.g., ".app.example.com")
# Leave empty for single-domain deployments
COOKIE_DOMAIN=.app.example.com

# Email
EMAIL_BACKEND=postmark
FROM_EMAIL=support@example.com
FROM_NAME=Example Support

# Postmark
POSTMARK_SERVER_TOKEN=
POSTMARK_WEBHOOK_SECRET=

# SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# SES
# SES_REGION=us-east-1
# SES_ACCESS_KEY=
# SES_SECRET_KEY=

# S3/Spaces Configuration (DigitalOcean Spaces or AWS S3)
# Used for attachment storage
S3_REGION=ams3
S3_ENDPOINT=https://ams3.digitaloceanspaces.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Attachment Storage Bucket
S3_ATTACHMENTS_BUCKET=

# Storage
STORAGE_TYPE=s3
STORAGE_PATH=/opt/mbr/data

# Cache
CACHE_ENABLED=true
CACHE_TTL=1h

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MIN=60

# Monitoring security
# Required in production to protect /metrics endpoint
METRICS_TOKEN=

# Trusted reverse proxies for correct client IP detection
# Keep loopback-only when Caddy runs on same host
TRUSTED_PROXIES=127.0.0.1,::1
